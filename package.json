{
  "name": "vscode-workflow-agent",
  "displayName": "Workflow Agent",
  "description": "Visual workflow orchestration system for VSCode with MCP support",
  "version": "0.1.0",
  "publisher": "li-mz26",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Debuggers",
    "Visualization"
  ],
  "keywords": [
    "workflow",
    "automation",
    "llm",
    "ai",
    "mcp",
    "visualization"
  ],
  "activationEvents": [
    "onLanguage:json",
    "onCommand:workflowAgent.open",
    "workspaceContains:**/*.workflow.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "workflowAgent.open",
        "title": "打开工作流",
        "icon": "$(git-branch)"
      },
      {
        "command": "workflowAgent.create",
        "title": "新建工作流",
        "icon": "$(add)"
      },
      {
        "command": "workflowAgent.openFolder",
        "title": "打开工作流文件夹",
        "icon": "$(folder-opened)"
      },
      {
        "command": "workflowAgent.closeFolder",
        "title": "关闭工作流文件夹",
        "icon": "$(close)"
      },
      {
        "command": "workflowAgent.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "workflowAgent.run",
        "title": "运行工作流",
        "icon": "$(play)"
      },
      {
        "command": "workflowAgent.debug",
        "title": "调试工作流",
        "icon": "$(debug-alt)"
      },
      {
        "command": "workflowAgent.stop",
        "title": "停止执行",
        "icon": "$(debug-stop)"
      },
      {
        "command": "workflowAgent.toggleMCP",
        "title": "启用/禁用 MCP 服务",
        "icon": "$(server)"
      },
      {
        "command": "workflowAgent.configureMCPPort",
        "title": "配置 MCP 端口",
        "icon": "$(ports-open-browser)"
      },
      {
        "command": "workflowAgent.openSettings",
        "title": "打开设置",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "workflowAgent.openSettings",
          "when": "view == workflowAgent.settings",
          "group": "navigation"
        },
        {
          "command": "workflowAgent.openFolder",
          "when": "view == workflowAgent.folders",
          "group": "navigation"
        },
        {
          "command": "workflowAgent.create",
          "when": "view == workflowAgent.explorer",
          "group": "navigation"
        },
        {
          "command": "workflowAgent.refresh",
          "when": "view == workflowAgent.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "workflowAgent.closeFolder",
          "when": "view == workflowAgent.folders && viewItem == workflowFolder"
        },
        {
          "command": "workflowAgent.open",
          "when": "view == workflowAgent.explorer && viewItem == workflow"
        }
      ],
      "commandPalette": [
        {
          "command": "workflowAgent.open",
          "when": "resourceExtname == .workflow.json"
        }
      ],
      "explorer/context": [
        {
          "command": "workflowAgent.open",
          "when": "resourceExtname == .workflow.json",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "workflowAgent.run",
          "when": "resourceExtname == .workflow.json",
          "group": "navigation"
        },
        {
          "command": "workflowAgent.debug",
          "when": "resourceExtname == .workflow.json",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "workflowAgent.editor",
        "displayName": "Workflow Editor",
        "selector": [
          {
            "filenamePattern": "*.workflow.json"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workflowAgent",
          "title": "Workflow Agent",
          "icon": "$(git-branch)"
        }
      ]
    },
    "views": {
      "workflowAgent": [
        {
          "id": "workflowAgent.settings",
          "name": "设置",
          "when": "true"
        },
        {
          "id": "workflowAgent.explorer",
          "name": "工作流列表",
          "when": "workspaceHasWorkflowFiles || workflowAgent:hasFolders"
        },
        {
          "id": "workflowAgent.folders",
          "name": "工作流文件夹",
          "when": "workflowAgent:hasFolders"
        }
      ]
    },
    "configuration": {
      "title": "Workflow Agent",
      "properties": {
        "workflowAgent.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python executable for code execution"
        },
        "workflowAgent.defaultLLMProvider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "anthropic",
            "local"
          ],
          "description": "Default LLM provider"
        },
        "workflowAgent.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API Key"
        },
        "workflowAgent.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key"
        },
        "workflowAgent.enableMCP": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP server"
        },
        "workflowAgent.mcpPort": {
          "type": "number",
          "default": 3000,
          "description": "MCP server port"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd webview && npm install && npm run build",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.32.0",
    "eslint": "^8.45.0",
    "typescript": "^5.1.0",
    "vitest": "^0.34.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "zod": "^3.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/limz26/vscode-workflow-agent"
  }
}
