{
  "id": "wf_conditional_branching",
  "name": "条件分支示例",
  "description": "根据条件选择不同的处理路径",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "node_start",
      "type": "start",
      "position": { "x": 50, "y": 200 },
      "inputs": [],
      "outputs": [
        { "id": "trigger", "name": "trigger", "type": "data", "dataType": "object", "required": true }
      ],
      "metadata": {
        "name": "开始",
        "description": "工作流入口",
        "icon": "play",
        "color": "#4CAF50"
      },
      "data": { "triggerType": "manual" }
    },
    {
      "id": "node_input",
      "type": "code",
      "position": { "x": 250, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "metadata": {
        "name": "准备数据",
        "description": "生成示例数据",
        "icon": "code",
        "color": "#2196F3"
      },
      "data": {
        "code": "def main(ctx):\n    import random\n    score = random.randint(0, 100)\n    return {'score': score, 'student': '张三'}",
        "timeout": 30
      }
    },
    {
      "id": "node_switch",
      "type": "switch",
      "position": { "x": 500, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": true }
      ],
      "outputs": [
        { "id": "excellent", "name": "优秀", "type": "control", "dataType": "any", "required": false },
        { "id": "good", "name": "良好", "type": "control", "dataType": "any", "required": false },
        { "id": "fail", "name": "不及格", "type": "control", "dataType": "any", "required": false }
      ],
      "metadata": {
        "name": "成绩判断",
        "description": "根据分数判断等级",
        "icon": "split-horizontal",
        "color": "#FF9800"
      },
      "data": {
        "conditions": [
          { "name": "优秀 (≥90)", "expression": "input.score >= 90", "target": "excellent" },
          { "name": "良好 (≥60)", "expression": "input.score >= 60", "target": "good" }
        ],
        "defaultTarget": "fail"
      }
    },
    {
      "id": "node_excellent",
      "type": "code",
      "position": { "x": 750, "y": 50 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "metadata": {
        "name": "优秀处理",
        "description": "优秀成绩处理",
        "icon": "code",
        "color": "#4CAF50"
      },
      "data": {
        "code": "def main(ctx):\n    data = ctx.get('input', {})\n    return {\n        'grade': 'A',\n        'message': f\"恭喜 {data.get('student')}！成绩优秀 ({data.get('score')}分)\",\n        'reward': '获得奖学金'
    }",
        "timeout": 30
      }
    },
    {
      "id": "node_good",
      "type": "code",
      "position": { "x": 750, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "metadata": {
        "name": "良好处理",
        "description": "良好成绩处理",
        "icon": "code",
        "color": "#2196F3"
      },
      "data": {
        "code": "def main(ctx):\n    data = ctx.get('input', {})\n    return {\n        'grade': 'B',\n        'message': f\"{data.get('student')} 成绩良好 ({data.get('score')}分)\",\n        'reward': '继续保持'
    }",
        "timeout": 30
      }
    },
    {
      "id": "node_fail",
      "type": "code",
      "position": { "x": 750, "y": 350 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "metadata": {
        "name": "不及格处理",
        "description": "不及格成绩处理",
        "icon": "code",
        "color": "#F44336"
      },
      "data": {
        "code": "def main(ctx):\n    data = ctx.get('input', {})\n    return {\n        'grade': 'F',\n        'message': f\"{data.get('student')} 需要补考 ({data.get('score')}分)\",\n        'reward': '请加强学习'
    }",
        "timeout": 30
      }
    },
    {
      "id": "node_merge",
      "type": "code",
      "position": { "x": 1000, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "metadata": {
        "name": "合并结果",
        "description": "汇总处理结果",
        "icon": "code",
        "color": "#9C27B0"
      },
      "data": {
        "code": "def main(ctx):\n    return ctx.get('input', {})",
        "timeout": 30
      }
    },
    {
      "id": "node_end",
      "type": "end",
      "position": { "x": 1200, "y": 200 },
      "inputs": [
        { "id": "result", "name": "result", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [],
      "metadata": {
        "name": "结束",
        "description": "工作流出口",
        "icon": "stop",
        "color": "#F44336"
      },
      "data": { "outputMapping": {} }
    }
  ],
  "edges": [
    {
      "id": "edge_start_input",
      "source": { "nodeId": "node_start", "portId": "trigger" },
      "target": { "nodeId": "node_input", "portId": "input" }
    },
    {
      "id": "edge_input_switch",
      "source": { "nodeId": "node_input", "portId": "output" },
      "target": { "nodeId": "node_switch", "portId": "input" }
    },
    {
      "id": "edge_switch_excellent",
      "source": { "nodeId": "node_switch", "portId": "excellent" },
      "target": { "nodeId": "node_excellent", "portId": "input" }
    },
    {
      "id": "edge_switch_good",
      "source": { "nodeId": "node_switch", "portId": "good" },
      "target": { "nodeId": "node_good", "portId": "input" }
    },
    {
      "id": "edge_switch_fail",
      "source": { "nodeId": "node_switch", "portId": "fail" },
      "target": { "nodeId": "node_fail", "portId": "input" }
    },
    {
      "id": "edge_excellent_merge",
      "source": { "nodeId": "node_excellent", "portId": "output" },
      "target": { "nodeId": "node_merge", "portId": "input" }
    },
    {
      "id": "edge_good_merge",
      "source": { "nodeId": "node_good", "portId": "output" },
      "target": { "nodeId": "node_merge", "portId": "input" }
    },
    {
      "id": "edge_fail_merge",
      "source": { "nodeId": "node_fail", "portId": "output" },
      "target": { "nodeId": "node_merge", "portId": "input" }
    },
    {
      "id": "edge_merge_end",
      "source": { "nodeId": "node_merge", "portId": "output" },
      "target": { "nodeId": "node_end", "portId": "result" }
    }
  ],
  "variables": [],
  "settings": {
    "timeout": 120,
    "logLevel": "info"
  }
}
