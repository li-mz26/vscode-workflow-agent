{
  "id": "wf_conditional_branching",
  "name": "条件分支示例",
  "description": "根据条件选择不同的处理路径",
  "version": "2.0.0",
  "nodes": [
    {
      "id": "node_start",
      "type": "start",
      "position": { "x": 50, "y": 200 },
      "inputs": [],
      "outputs": [
        { "id": "trigger", "name": "trigger", "type": "data", "dataType": "object", "required": true }
      ],
      "data": { "triggerType": "manual" }
    },
    {
      "id": "node_input",
      "type": "code",
      "position": { "x": 250, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configRef": "03-conditional-branching.config/code/node_input.json"
    },
    {
      "id": "node_switch",
      "type": "switch",
      "position": { "x": 500, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": true }
      ],
      "outputs": [
        { "id": "excellent", "name": "优秀", "type": "control", "dataType": "any", "required": false },
        { "id": "good", "name": "良好", "type": "control", "dataType": "any", "required": false },
        { "id": "fail", "name": "不及格", "type": "control", "dataType": "any", "required": false }
      ],
      "configRef": "03-conditional-branching.config/switch/node_switch.json"
    },
    {
      "id": "node_excellent",
      "type": "code",
      "position": { "x": 750, "y": 50 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configRef": "03-conditional-branching.config/code/node_excellent.json"
    },
    {
      "id": "node_good",
      "type": "code",
      "position": { "x": 750, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configRef": "03-conditional-branching.config/code/node_good.json"
    },
    {
      "id": "node_fail",
      "type": "code",
      "position": { "x": 750, "y": 350 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configRef": "03-conditional-branching.config/code/node_fail.json"
    },
    {
      "id": "node_merge",
      "type": "code",
      "position": { "x": 1000, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configRef": "03-conditional-branching.config/code/node_merge.json"
    },
    {
      "id": "node_end",
      "type": "end",
      "position": { "x": 1200, "y": 200 },
      "inputs": [
        { "id": "result", "name": "result", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [],
      "data": { "outputMapping": {} }
    }
  ],
  "edges": [
    { "id": "edge_start_input", "source": { "nodeId": "node_start", "portId": "trigger" }, "target": { "nodeId": "node_input", "portId": "input" } },
    { "id": "edge_input_switch", "source": { "nodeId": "node_input", "portId": "output" }, "target": { "nodeId": "node_switch", "portId": "input" } },
    { "id": "edge_switch_excellent", "source": { "nodeId": "node_switch", "portId": "excellent" }, "target": { "nodeId": "node_excellent", "portId": "input" } },
    { "id": "edge_switch_good", "source": { "nodeId": "node_switch", "portId": "good" }, "target": { "nodeId": "node_good", "portId": "input" } },
    { "id": "edge_switch_fail", "source": { "nodeId": "node_switch", "portId": "fail" }, "target": { "nodeId": "node_fail", "portId": "input" } },
    { "id": "edge_excellent_merge", "source": { "nodeId": "node_excellent", "portId": "output" }, "target": { "nodeId": "node_merge", "portId": "input" } },
    { "id": "edge_good_merge", "source": { "nodeId": "node_good", "portId": "output" }, "target": { "nodeId": "node_merge", "portId": "input" } },
    { "id": "edge_fail_merge", "source": { "nodeId": "node_fail", "portId": "output" }, "target": { "nodeId": "node_merge", "portId": "input" } },
    { "id": "edge_merge_end", "source": { "nodeId": "node_merge", "portId": "output" }, "target": { "nodeId": "node_end", "portId": "result" } }
  ],
  "variables": [],
  "settings": { "timeout": 120, "logLevel": "info" }
}
