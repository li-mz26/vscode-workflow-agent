{
  "id": "wf_data_analysis_pipeline",
  "name": "数据分析与告警管道",
  "description": "从API获取数据，进行分析处理，根据条件发送告警的完整工作流",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "node_start",
      "type": "start",
      "position": { "x": 50, "y": 200 },
      "data": { "triggerType": "schedule" },
      "inputs": [],
      "outputs": [{ "id": "trigger", "name": "trigger", "type": "data", "dataType": "object", "required": true }],
      "metadata": { "name": "开始", "description": "Entry point", "icon": "play", "color": "#4CAF50" }
    },
    {
      "id": "node_fetch_data",
      "type": "http",
      "position": { "x": 250, "y": 200 },
      "data": {
        "method": "GET",
        "url": "https://api.example.com/metrics",
        "headers": { "Authorization": "Bearer {{api_token}}", "Content-Type": "application/json" },
        "timeout": 30000,
        "retryCount": 3
      },
      "inputs": [{ "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }],
      "outputs": [
        { "id": "status", "name": "status", "type": "data", "dataType": "number", "required": true },
        { "id": "body", "name": "body", "type": "data", "dataType": "string", "required": true },
        { "id": "json", "name": "json", "type": "data", "dataType": "object", "required": false }
      ],
      "metadata": { "name": "获取监控数据", "description": "从API拉取系统指标数据", "icon": "globe", "color": "#607D8B" }
    },
    {
      "id": "node_validate",
      "type": "code",
      "position": { "x": 450, "y": 200 },
      "data": {
        "code": "def main(ctx):\n    import json\n    data = ctx.get('input', {})\n    \n    if not data:\n        return { 'valid': False, 'error': 'Empty data', 'metrics': [] }\n    \n    # 验证数据结构\n    if 'metrics' not in data:\n        return { 'valid': False, 'error': 'Missing metrics field', 'metrics': [] }\n    \n    metrics = data['metrics']\n    \n    # 计算统计值\n    cpu_values = [m['cpu'] for m in metrics if 'cpu' in m]\n    memory_values = [m['memory'] for m in metrics if 'memory' in m]\n    \n    result = {\n        'valid': True,\n        'metrics': metrics,\n        'stats': {\n            'cpu_avg': sum(cpu_values) / len(cpu_values) if cpu_values else 0,\n            'cpu_max': max(cpu_values) if cpu_values else 0,\n            'memory_avg': sum(memory_values) / len(memory_values) if memory_values else 0,\n            'memory_max': max(memory_values) if memory_values else 0\n        },\n        'alerts': []\n    }\n    \n    # 检查告警条件\n    if result['stats']['cpu_max'] > 80:\n        result['alerts'].append({ 'type': 'cpu_high', 'value': result['stats']['cpu_max'] })\n    if result['stats']['memory_max'] > 90:\n        result['alerts'].append({ 'type': 'memory_critical', 'value': result['stats']['memory_max'] })\n    \n    return result",
        "timeout": 30,
        "environment": {}
      },
      "inputs": [{ "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }],
      "outputs": [{ "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }],
      "metadata": { "name": "数据验证与分析", "description": "验证数据并计算统计指标", "icon": "code", "color": "#2196F3" }
    },
    {
      "id": "node_llm_analysis",
      "type": "llm",
      "position": { "x": 650, "y": 100 },
      "data": {
        "model": "gpt-4",
        "systemPrompt": "你是一个系统监控分析专家。分析提供的数据并给出简洁的总结和建议。",
        "temperature": 0.3,
        "maxTokens": 500
      },
      "inputs": [
        { "id": "prompt", "name": "prompt", "type": "data", "dataType": "string", "required": true },
        { "id": "context", "name": "context", "type": "data", "dataType": "string", "required": false }
      ],
      "outputs": [
        { "id": "content", "name": "content", "type": "data", "dataType": "string", "required": true },
        { "id": "usage", "name": "usage", "type": "data", "dataType": "object", "required": true }
      ],
      "metadata": { "name": "智能分析", "description": "使用LLM分析系统状态", "icon": "sparkle", "color": "#9C27B0" }
    },
    {
      "id": "node_check_alerts",
      "type": "switch",
      "position": { "x": 650, "y": 300 },
      "data": {
        "conditions": [
          { "name": "有严重告警", "expression": "len(alerts) > 0 and any(a.type == 'memory_critical' for a in alerts)", "target": "critical" },
          { "name": "有一般告警", "expression": "len(alerts) > 0", "target": "warning" },
          { "name": "正常", "expression": "len(alerts) == 0", "target": "normal" }
        ],
        "defaultTarget": "normal"
      },
      "inputs": [{ "id": "input", "name": "input", "type": "data", "dataType": "any", "required": true }],
      "outputs": [
        { "id": "branch_0", "name": "严重告警分支", "type": "control", "dataType": "any", "required": false },
        { "id": "branch_1", "name": "一般告警分支", "type": "control", "dataType": "any", "required": false },
        { "id": "branch_2", "name": "正常分支", "type": "control", "dataType": "any", "required": false }
      ],
      "metadata": { "name": "告警检查", "description": "根据分析结果分流", "icon": "split-horizontal", "color": "#FF9800" }
    },
    {
      "id": "node_parallel_start",
      "type": "parallel",
      "position": { "x": 850, "y": 200 },
      "data": {
        "branches": [
          { "name": "发送告警", "id": "send_alert" },
          { "name": "保存日志", "id": "save_log" }
        ]
      },
      "inputs": [{ "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }],
      "outputs": [
        { "id": "send_alert", "name": "发送告警", "type": "control", "dataType": "any", "required": false },
        { "id": "save_log", "name": "保存日志", "type": "control", "dataType": "any", "required": false }
      ],
      "metadata": { "name": "并行处理", "description": "同时执行多个操作", "icon": "git-branch", "color": "#00BCD4" }
    },
    {
      "id": "node_webhook_critical",
      "type": "webhook",
      "position": { "x": 1050, "y": 100 },
      "data": {
        "provider": "slack",
        "webhookUrl": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
        "title": "🚨 严重系统告警",
        "message": "检测到系统资源使用率过高，请立即处理！\n\n{{analysis_summary}}",
        "severity": "critical",
        "fields": [
          { "name": "CPU峰值", "value": "{{cpu_max}}%", "short": true },
          { "name": "内存峰值", "value": "{{memory_max}}%", "short": true },
          { "name": "触发时间", "value": "{{timestamp}}", "short": false }
        ],
        "mentions": ["@oncall"]
      },
      "inputs": [{ "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }],
      "outputs": [{ "id": "sent", "name": "sent", "type": "data", "dataType": "boolean", "required": true }],
      "metadata": { "name": "发送严重告警", "description": "发送Slack紧急通知", "icon": "bell", "color": "#E91E63" }
    },
    {
      "id": "node_webhook_warning",
      "type": "webhook",
      "position": { "x": 1050, "y": 250 },
      "data": {
        "provider": "slack",
        "webhookUrl": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
        "title": "⚠️ 系统告警",
        "message": "系统资源使用率偏高，请关注。\n\n{{analysis_summary}}",
        "severity": "warning",
        "fields": [
          { "name": "CPU平均", "value": "{{cpu_avg}}%", "short": true },
          { "name": "内存平均", "value": "{{memory_avg}}%", "short": true }
        ],
        "mentions": []
      },
      "inputs": [{ "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }],
      "outputs": [{ "id": "sent", "name": "sent", "type": "data", "dataType": "boolean", "required": true }],
      "metadata": { "name": "发送一般告警", "description": "发送Slack通知", "icon": "bell", "color": "#FF9800" }
    },
    {
      "id": "node_save_log",
      "type": "code",
      "position": { "x": 1050, "y": 400 },
      "data": {
        "code": "def main(ctx):\n    import json\n    from datetime import datetime\n    \n    data = ctx.get('input', {})\n    \n    # 构建日志条目\n    log_entry = {\n        'timestamp': datetime.now().isoformat(),\n        'workflow_id': ctx.get('workflow_id', 'unknown'),\n        'execution_id': ctx.get('execution_id', 'unknown'),\n        'data': data,\n        'level': 'INFO' if not data.get('alerts') else 'WARNING'\n    }\n    \n    # 这里可以写入文件或数据库\n    # with open('/var/log/workflow.log', 'a') as f:\n    #     f.write(json.dumps(log_entry) + '\\n')\n    \n    print(f\"[LOG] {log_entry['timestamp']} - {log_entry['level']} - Workflow executed\")\n    \n    return { 'saved': True, 'log_id': log_entry['timestamp'] }",
        "timeout": 10,
        "environment": {}
      },
      "inputs": [{ "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }],
      "outputs": [{ "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }],
      "metadata": { "name": "保存执行日志", "description": "记录执行历史", "icon": "code", "color": "#795548" }
    },
    {
      "id": "node_merge",
      "type": "merge",
      "position": { "x": 1250, "y": 200 },
      "data": {
        "strategy": "all",
        "timeout": 60
      },
      "inputs": [
        { "id": "input_0", "name": "分支1结果", "type": "data", "dataType": "any", "required": false },
        { "id": "input_1", "name": "分支2结果", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [{ "id": "result", "name": "result", "type": "data", "dataType": "object", "required": true }],
      "metadata": { "name": "合并结果", "description": "等待所有分支完成", "icon": "git-merge", "color": "#795548" }
    },
    {
      "id": "node_end",
      "type": "end",
      "position": { "x": 1450, "y": 200 },
      "data": { "outputMapping": {} },
      "inputs": [{ "id": "result", "name": "result", "type": "data", "dataType": "any", "required": false }],
      "outputs": [],
      "metadata": { "name": "结束", "description": "Exit point", "icon": "stop", "color": "#F44336" }
    }
  ],
  "edges": [
    { "id": "edge_start_fetch", "source": { "nodeId": "node_start", "portId": "trigger" }, "target": { "nodeId": "node_fetch_data", "portId": "input" } },
    { "id": "edge_fetch_validate", "source": { "nodeId": "node_fetch_data", "portId": "json" }, "target": { "nodeId": "node_validate", "portId": "input" } },
    { "id": "edge_validate_llm", "source": { "nodeId": "node_validate", "portId": "output" }, "target": { "nodeId": "node_llm_analysis", "portId": "prompt" } },
    { "id": "edge_validate_check", "source": { "nodeId": "node_validate", "portId": "output" }, "target": { "nodeId": "node_check_alerts", "portId": "input" } },
    { "id": "edge_check_parallel", "source": { "nodeId": "node_check_alerts", "portId": "branch_0" }, "target": { "nodeId": "node_parallel_start", "portId": "input" } },
    { "id": "edge_parallel_webhook", "source": { "nodeId": "node_parallel_start", "portId": "send_alert" }, "target": { "nodeId": "node_webhook_critical", "portId": "input" } },
    { "id": "edge_parallel_log", "source": { "nodeId": "node_parallel_start", "portId": "save_log" }, "target": { "nodeId": "node_save_log", "portId": "input" } },
    { "id": "edge_webhook_merge", "source": { "nodeId": "node_webhook_critical", "portId": "sent" }, "target": { "nodeId": "node_merge", "portId": "input_0" } },
    { "id": "edge_log_merge", "source": { "nodeId": "node_save_log", "portId": "output" }, "target": { "nodeId": "node_merge", "portId": "input_1" } },
    { "id": "edge_merge_end", "source": { "nodeId": "node_merge", "portId": "result" }, "target": { "nodeId": "node_end", "portId": "result" } }
  ],
  "variables": [
    { "name": "api_token", "type": "string", "defaultValue": "", "description": "API认证令牌" },
    { "name": "webhook_url", "type": "string", "defaultValue": "", "description": "Slack Webhook地址" },
    { "name": "cpu_threshold", "type": "number", "defaultValue": 80, "description": "CPU告警阈值" },
    { "name": "memory_threshold", "type": "number", "defaultValue": 90, "description": "内存告警阈值" }
  ],
  "settings": {
    "timeout": 120,
    "logLevel": "info"
  },
  "createdAt": "2026-03-06T15:35:00.000Z",
  "updatedAt": "2026-03-06T15:35:00.000Z"
}
