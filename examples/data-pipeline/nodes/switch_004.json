{
  "description": "根据分析结果的优先级选择处理路径",
  "conditions": [
    {
      "name": "high",
      "expression": "input.priority === 'high' || input.score >= 80",
      "target": "node_http_005"
    },
    {
      "name": "medium",
      "expression": "input.priority === 'medium' || (input.score >= 50 && input.score < 80)",
      "target": "node_end_006"
    },
    {
      "name": "low",
      "expression": "true",
      "target": "node_end_006"
    }
  ],
  "defaultTarget": "node_end_006"
}