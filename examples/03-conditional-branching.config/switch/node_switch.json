{
  "$schema": "https://workflow-agent/config/switch-node.json",
  "type": "switch",
  "conditions": [
    {
      "name": "优秀 (≥90)",
      "expression": "input.score >= 90",
      "target": "excellent",
      "description": "分数大于等于90分"
    },
    {
      "name": "良好 (≥60)",
      "expression": "input.score >= 60",
      "target": "good",
      "description": "分数大于等于60分但小于90分"
    }
  ],
  "defaultTarget": "fail",
  "defaultDescription": "分数小于60分，不及格"
}
