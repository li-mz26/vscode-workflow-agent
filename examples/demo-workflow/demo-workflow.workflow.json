{
  "id": "wf_demo_001",
  "name": "demo-workflow",
  "description": "示例工作流 - 数据处理与条件分支",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "node_start",
      "type": "start",
      "position": { "x": 100, "y": 300 },
      "configRef": "nodes/node_start.json",
      "metadata": {
        "name": "开始",
        "description": "工作流入口"
      }
    },
    {
      "id": "node_fetch_data",
      "type": "code",
      "position": { "x": 300, "y": 300 },
      "configRef": "nodes/node_fetch_data.py",
      "metadata": {
        "name": "获取数据",
        "description": "生成模拟数据"
      }
    },
    {
      "id": "node_check_score",
      "type": "switch",
      "position": { "x": 500, "y": 250 },
      "configRef": "nodes/node_check_score.json",
      "metadata": {
        "name": "分数判断",
        "description": "根据分数分支"
      },
      "detail": {
        "branches": [
          { "id": "branch_high", "name": "高分", "condition": "data.avg_score >= 80" },
          { "id": "branch_low", "name": "低分", "condition": "true" }
        ],
        "defaultBranch": "branch_low"
      }
    },
    {
      "id": "node_process_high",
      "type": "code",
      "position": { "x": 750, "y": 150 },
      "configRef": "nodes/node_process_high.py",
      "metadata": {
        "name": "高分处理",
        "description": "分数>=80的处理"
      }
    },
    {
      "id": "node_process_low",
      "type": "code",
      "position": { "x": 750, "y": 400 },
      "configRef": "nodes/node_process_low.py",
      "metadata": {
        "name": "低分处理",
        "description": "分数<80的处理"
      }
    },
    {
      "id": "node_summary",
      "type": "code",
      "position": { "x": 1000, "y": 300 },
      "configRef": "nodes/node_summary.py",
      "metadata": {
        "name": "汇总结果",
        "description": "合并处理结果"
      }
    },
    {
      "id": "node_end",
      "type": "end",
      "position": { "x": 1250, "y": 300 },
      "configRef": "nodes/node_end.json",
      "metadata": {
        "name": "结束",
        "description": "工作流出口"
      }
    }
  ],
  "edges": [
    {
      "id": "edge_001",
      "source": { "nodeId": "node_start", "portId": "output" },
      "target": { "nodeId": "node_fetch_data", "portId": "input" }
    },
    {
      "id": "edge_002",
      "source": { "nodeId": "node_fetch_data", "portId": "output" },
      "target": { "nodeId": "node_check_score", "portId": "input" }
    },
    {
      "id": "edge_003",
      "source": { "nodeId": "node_check_score", "portId": "output" },
      "target": { "nodeId": "node_process_high", "portId": "input" },
      "branchId": "branch_high"
    },
    {
      "id": "edge_004",
      "source": { "nodeId": "node_check_score", "portId": "output" },
      "target": { "nodeId": "node_process_low", "portId": "input" },
      "branchId": "branch_low"
    },
    {
      "id": "edge_005",
      "source": { "nodeId": "node_process_high", "portId": "output" },
      "target": { "nodeId": "node_summary", "portId": "input" }
    },
    {
      "id": "edge_006",
      "source": { "nodeId": "node_process_low", "portId": "output" },
      "target": { "nodeId": "node_summary", "portId": "input" }
    },
    {
      "id": "edge_007",
      "source": { "nodeId": "node_summary", "portId": "output" },
      "target": { "nodeId": "node_end", "portId": "input" }
    }
  ],
  "metadata": {
    "author": "demo",
    "createdAt": "2026-03-12T00:00:00.000Z",
    "updatedAt": "2026-03-12T09:00:00.000Z",
    "tags": ["demo", "example", "branch"]
  }
}