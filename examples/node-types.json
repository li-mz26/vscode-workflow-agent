{
  "version": "1.0.0",
  "description": "VSCode Workflow Agent 支持的节点类型定义",
  "categories": [
    {
      "id": "basic",
      "name": "基础节点",
      "description": "工作流的基本构建块"
    },
    {
      "id": "flow",
      "name": "流程控制",
      "description": "控制工作流执行路径"
    },
    {
      "id": "integration",
      "name": "集成",
      "description": "与外部系统交互"
    }
  ],
  "nodeTypes": [
    {
      "type": "start",
      "category": "basic",
      "name": "开始",
      "description": "工作流入口点",
      "icon": "play",
      "color": "#4CAF50",
      "inputs": [],
      "outputs": [
        { "id": "trigger", "name": "trigger", "type": "data", "dataType": "object", "required": true }
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "triggerType": {
            "type": "string",
            "enum": ["manual", "api", "schedule"],
            "default": "manual",
            "description": "触发方式"
          }
        }
      },
      "defaultData": { "triggerType": "manual" }
    },
    {
      "type": "end",
      "category": "basic",
      "name": "结束",
      "description": "工作流出口点",
      "icon": "stop",
      "color": "#F44336",
      "inputs": [
        { "id": "result", "name": "result", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [],
      "configSchema": {
        "type": "object",
        "properties": {
          "outputMapping": {
            "type": "object",
            "description": "输出映射"
          }
        }
      },
      "defaultData": { "outputMapping": {} }
    },
    {
      "type": "code",
      "category": "basic",
      "name": "代码执行",
      "description": "执行 Python 代码",
      "icon": "code",
      "color": "#2196F3",
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Python 代码",
            "default": "def main(ctx):\n    return ctx.input"
          },
          "timeout": {
            "type": "number",
            "description": "执行超时（秒）",
            "default": 30
          }
        },
        "required": ["code"]
      },
      "defaultData": {
        "code": "def main(ctx):\n    return ctx.input",
        "timeout": 30
      }
    },
    {
      "type": "llm",
      "category": "basic",
      "name": "LLM",
      "description": "调用大语言模型",
      "icon": "sparkle",
      "color": "#9C27B0",
      "inputs": [
        { "id": "prompt", "name": "prompt", "type": "data", "dataType": "string", "required": true },
        { "id": "context", "name": "context", "type": "data", "dataType": "string", "required": false }
      ],
      "outputs": [
        { "id": "content", "name": "content", "type": "data", "dataType": "string", "required": true },
        { "id": "usage", "name": "usage", "type": "data", "dataType": "object", "required": true }
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "模型名称",
            "default": "gpt-4"
          },
          "systemPrompt": {
            "type": "string",
            "description": "系统提示词"
          },
          "temperature": {
            "type": "number",
            "description": "温度 (0-2)",
            "default": 0.7,
            "minimum": 0,
            "maximum": 2
          },
          "maxTokens": {
            "type": "number",
            "description": "最大 token 数",
            "default": 2000
          }
        },
        "required": ["model"]
      },
      "defaultData": {
        "model": "gpt-4",
        "temperature": 0.7,
        "maxTokens": 2000
      }
    },
    {
      "type": "switch",
      "category": "flow",
      "name": "条件分支",
      "description": "根据条件选择分支",
      "icon": "split-horizontal",
      "color": "#FF9800",
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": true }
      ],
      "outputs": [],
      "configSchema": {
        "type": "object",
        "properties": {
          "conditions": {
            "type": "array",
            "description": "分支条件",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "expression": { "type": "string" },
                "target": { "type": "string" }
              }
            }
          },
          "defaultTarget": {
            "type": "string",
            "description": "默认分支"
          }
        }
      },
      "defaultData": {
        "conditions": [],
        "defaultTarget": "default"
      }
    },
    {
      "type": "parallel",
      "category": "flow",
      "name": "并行",
      "description": "并行执行多个分支",
      "icon": "git-branch",
      "color": "#00BCD4",
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [],
      "configSchema": {
        "type": "object",
        "properties": {
          "branches": {
            "type": "array",
            "description": "并行分支",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "id": { "type": "string" }
              }
            }
          }
        }
      },
      "defaultData": {
        "branches": [
          { "name": "分支 1", "id": "branch1" },
          { "name": "分支 2", "id": "branch2" }
        ]
      }
    },
    {
      "type": "merge",
      "category": "flow",
      "name": "合并",
      "description": "合并并行分支",
      "icon": "git-merge",
      "color": "#795548",
      "inputs": [],
      "outputs": [
        { "id": "result", "name": "result", "type": "data", "dataType": "object", "required": true }
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "strategy": {
            "type": "string",
            "enum": ["all", "any"],
            "default": "all",
            "description": "等待所有分支还是任意分支"
          },
          "timeout": {
            "type": "number",
            "description": "超时（秒）",
            "default": 60
          }
        }
      },
      "defaultData": {
        "strategy": "all",
        "timeout": 60
      }
    },
    {
      "type": "http",
      "category": "integration",
      "name": "HTTP 请求",
      "description": "调用外部 API",
      "icon": "globe",
      "color": "#607D8B",
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "status", "name": "status", "type": "data", "dataType": "number", "required": true },
        { "id": "body", "name": "body", "type": "data", "dataType": "string", "required": true },
        { "id": "json", "name": "json", "type": "data", "dataType": "object", "required": false }
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
            "default": "GET",
            "description": "HTTP 方法"
          },
          "url": {
            "type": "string",
            "description": "请求 URL"
          },
          "headers": {
            "type": "object",
            "description": "请求头",
            "default": {}
          },
          "body": {
            "type": "string",
            "description": "请求体"
          },
          "timeout": {
            "type": "number",
            "default": 30000,
            "description": "超时（毫秒）"
          },
          "retryCount": {
            "type": "number",
            "default": 0,
            "description": "重试次数"
          }
        },
        "required": ["url"]
      },
      "defaultData": {
        "method": "GET",
        "url": "",
        "headers": {},
        "timeout": 30000,
        "retryCount": 0
      }
    },
    {
      "type": "webhook",
      "category": "integration",
      "name": "Webhook",
      "description": "发送通知到 Slack、钉钉、Discord 等",
      "icon": "bell",
      "color": "#E91E63",
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "sent", "name": "sent", "type": "data", "dataType": "boolean", "required": true }
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["slack", "dingtalk", "discord", "pagerduty", "generic"],
            "default": "slack",
            "description": "Webhook 提供商"
          },
          "webhookUrl": {
            "type": "string",
            "description": "Webhook URL"
          },
          "title": {
            "type": "string",
            "description": "消息标题"
          },
          "message": {
            "type": "string",
            "description": "消息内容"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error", "critical"],
            "default": "info"
          }
        },
        "required": ["webhookUrl", "message"]
      },
      "defaultData": {
        "provider": "slack",
        "severity": "info"
      }
    },
    {
      "type": "schedule",
      "category": "flow",
      "name": "定时触发",
      "description": "使用 Cron 表达式定时触发",
      "icon": "clock",
      "color": "#FF5722",
      "inputs": [],
      "outputs": [
        { "id": "trigger", "name": "trigger", "type": "data", "dataType": "object", "required": true }
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "cronExpression": {
            "type": "string",
            "description": "Cron 表达式，如 0 */5 * * *"
          },
          "timezone": {
            "type": "string",
            "default": "UTC",
            "description": "时区"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          }
        },
        "required": ["cronExpression"]
      },
      "defaultData": {
        "cronExpression": "0 */5 * * *",
        "timezone": "UTC",
        "enabled": true
      }
    }
  ]
}
