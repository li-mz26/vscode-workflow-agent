{
  "id": "wf_llm_text_analysis",
  "name": "LLM 文本分析",
  "description": "使用大语言模型分析文本情感和内容",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "node_start",
      "type": "start",
      "position": { "x": 50, "y": 200 },
      "inputs": [],
      "outputs": [
        { "id": "trigger", "name": "trigger", "type": "data", "dataType": "object", "required": true }
      ],
      "metadata": {
        "name": "开始",
        "description": "工作流入口",
        "icon": "play",
        "color": "#4CAF50"
      },
      "data": { "triggerType": "manual" }
    },
    {
      "id": "node_prepare",
      "type": "code",
      "position": { "x": 300, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "metadata": {
        "name": "准备文本",
        "description": "准备待分析的文本",
        "icon": "code",
        "color": "#2196F3"
      },
      "data": {
        "code": "def main(ctx):\n    # 示例文本，实际可以从输入获取\n    text = ctx.get('input', {}).get('text', '''\n    这款产品真的太棒了！完全符合我的期望。\n    虽然价格有点贵，但是质量真的很好，值得。\n    客服态度也非常好，有问必答。\n    ''').strip()\n    \n    return {'text': text, 'source': 'user_input'}",
        "timeout": 30
      }
    },
    {
      "id": "node_llm_sentiment",
      "type": "llm",
      "position": { "x": 600, "y": 100 },
      "inputs": [
        { "id": "prompt", "name": "prompt", "type": "data", "dataType": "string", "required": true },
        { "id": "context", "name": "context", "type": "data", "dataType": "string", "required": false }
      ],
      "outputs": [
        { "id": "content", "name": "content", "type": "data", "dataType": "string", "required": true },
        { "id": "usage", "name": "usage", "type": "data", "dataType": "object", "required": true }
      ],
      "metadata": {
        "name": "情感分析",
        "description": "分析文本情感倾向",
        "icon": "sparkle",
        "color": "#9C27B0"
      },
      "data": {
        "model": "gpt-4",
        "systemPrompt": "你是一个专业的文本情感分析助手。分析给定文本的情感倾向，以 JSON 格式返回结果。",
        "temperature": 0.3,
        "maxTokens": 500
      }
    },
    {
      "id": "node_llm_summary",
      "type": "llm",
      "position": { "x": 600, "y": 300 },
      "inputs": [
        { "id": "prompt", "name": "prompt", "type": "data", "dataType": "string", "required": true },
        { "id": "context", "name": "context", "type": "data", "dataType": "string", "required": false }
      ],
      "outputs": [
        { "id": "content", "name": "content", "type": "data", "dataType": "string", "required": true },
        { "id": "usage", "name": "usage", "type": "data", "dataType": "object", "required": true }
      ],
      "metadata": {
        "name": "内容摘要",
        "description": "生成文本摘要",
        "icon": "sparkle",
        "color": "#9C27B0"
      },
      "data": {
        "model": "gpt-4",
        "systemPrompt": "你是一个专业的文本摘要助手。为给定文本生成简洁的摘要。",
        "temperature": 0.5,
        "maxTokens": 300
      }
    },
    {
      "id": "node_format",
      "type": "code",
      "position": { "x": 900, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "metadata": {
        "name": "格式化结果",
        "description": "整合分析结果",
        "icon": "code",
        "color": "#2196F3"
      },
      "data": {
        "code": "def main(ctx):\n    data = ctx.get('input', {})\n    sentiment = data.get('sentiment', '未知')\n    summary = data.get('summary', '无摘要')\n    original = data.get('original', '')\n    \n    return {\n        'original_text': original[:200] + '...' if len(original) > 200 else original,\n        'sentiment_analysis': sentiment,\n        'summary': summary,\n        'word_count': len(original.split()),\n        'analyzed_at': __import__('datetime').datetime.now().isoformat()\n    }",
        "timeout": 30
      }
    },
    {
      "id": "node_end",
      "type": "end",
      "position": { "x": 1150, "y": 200 },
      "inputs": [
        { "id": "result", "name": "result", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [],
      "metadata": {
        "name": "结束",
        "description": "工作流出口",
        "icon": "stop",
        "color": "#F44336"
      },
      "data": { "outputMapping": {} }
    }
  ],
  "edges": [
    {
      "id": "edge_start_prepare",
      "source": { "nodeId": "node_start", "portId": "trigger" },
      "target": { "nodeId": "node_prepare", "portId": "input" }
    },
    {
      "id": "edge_prepare_sentiment",
      "source": { "nodeId": "node_prepare", "portId": "output" },
      "target": { "nodeId": "node_llm_sentiment", "portId": "prompt" }
    },
    {
      "id": "edge_prepare_summary",
      "source": { "nodeId": "node_prepare", "portId": "output" },
      "target": { "nodeId": "node_llm_summary", "portId": "prompt" }
    },
    {
      "id": "edge_sentiment_format",
      "source": { "nodeId": "node_llm_sentiment", "portId": "content" },
      "target": { "nodeId": "node_format", "portId": "input" }
    },
    {
      "id": "edge_summary_format",
      "source": { "nodeId": "node_llm_summary", "portId": "content" },
      "target": { "nodeId": "node_format", "portId": "input" }
    },
    {
      "id": "edge_format_end",
      "source": { "nodeId": "node_format", "portId": "output" },
      "target": { "nodeId": "node_end", "portId": "result" }
    }
  ],
  "variables": [
    { "name": "openai_api_key", "type": "string", "defaultValue": "" }
  ],
  "settings": {
    "timeout": 300,
    "logLevel": "info"
  }
}
