{
  "id": "wf_llm_text_analysis",
  "name": "LLM 文本分析",
  "description": "使用大语言模型分析文本情感和内容",
  "version": "2.0.0",
  "nodes": [
    {
      "id": "node_start",
      "type": "start",
      "position": { "x": 50, "y": 200 },
      "inputs": [],
      "outputs": [
        { "id": "trigger", "name": "trigger", "type": "data", "dataType": "object", "required": true }
      ],
      "data": { "triggerType": "manual" }
    },
    {
      "id": "node_prepare",
      "type": "code",
      "position": { "x": 300, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configRef": "05-llm-text-analysis.config/code/node_prepare.json"
    },
    {
      "id": "node_llm_sentiment",
      "type": "llm",
      "position": { "x": 600, "y": 100 },
      "inputs": [
        { "id": "prompt", "name": "prompt", "type": "data", "dataType": "string", "required": true },
        { "id": "context", "name": "context", "type": "data", "dataType": "string", "required": false }
      ],
      "outputs": [
        { "id": "content", "name": "content", "type": "data", "dataType": "string", "required": true },
        { "id": "usage", "name": "usage", "type": "data", "dataType": "object", "required": true }
      ],
      "configRef": "05-llm-text-analysis.config/llm/node_sentiment.json"
    },
    {
      "id": "node_llm_summary",
      "type": "llm",
      "position": { "x": 600, "y": 300 },
      "inputs": [
        { "id": "prompt", "name": "prompt", "type": "data", "dataType": "string", "required": true },
        { "id": "context", "name": "context", "type": "data", "dataType": "string", "required": false }
      ],
      "outputs": [
        { "id": "content", "name": "content", "type": "data", "dataType": "string", "required": true },
        { "id": "usage", "name": "usage", "type": "data", "dataType": "object", "required": true }
      ],
      "configRef": "05-llm-text-analysis.config/llm/node_summary.json"
    },
    {
      "id": "node_format",
      "type": "code",
      "position": { "x": 900, "y": 200 },
      "inputs": [
        { "id": "input", "name": "input", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [
        { "id": "output", "name": "output", "type": "data", "dataType": "any", "required": true }
      ],
      "configRef": "05-llm-text-analysis.config/code/node_format.json"
    },
    {
      "id": "node_end",
      "type": "end",
      "position": { "x": 1150, "y": 200 },
      "inputs": [
        { "id": "result", "name": "result", "type": "data", "dataType": "any", "required": false }
      ],
      "outputs": [],
      "data": { "outputMapping": {} }
    }
  ],
  "edges": [
    { "id": "edge_start_prepare", "source": { "nodeId": "node_start", "portId": "trigger" }, "target": { "nodeId": "node_prepare", "portId": "input" } },
    { "id": "edge_prepare_sentiment", "source": { "nodeId": "node_prepare", "portId": "output" }, "target": { "nodeId": "node_llm_sentiment", "portId": "prompt" } },
    { "id": "edge_prepare_summary", "source": { "nodeId": "node_prepare", "portId": "output" }, "target": { "nodeId": "node_llm_summary", "portId": "prompt" } },
    { "id": "edge_sentiment_format", "source": { "nodeId": "node_llm_sentiment", "portId": "content" }, "target": { "nodeId": "node_format", "portId": "input" } },
    { "id": "edge_summary_format", "source": { "nodeId": "node_llm_summary", "portId": "content" }, "target": { "nodeId": "node_format", "portId": "input" } },
    { "id": "edge_format_end", "source": { "nodeId": "node_format", "portId": "output" }, "target": { "nodeId": "node_end", "portId": "result" } }
  ],
  "variables": [
    { "name": "openai_api_key", "type": "string", "defaultValue": "" }
  ],
  "settings": { "timeout": 300, "logLevel": "info" }
}
